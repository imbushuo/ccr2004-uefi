##

################################################################################
#
# FD Section
#
################################################################################

[FD.CCR2004]
BaseAddress   = 0x01100000|gArmTokenSpaceGuid.PcdFdBaseAddress
Size          = 0x00380000|gArmTokenSpaceGuid.PcdFdSize
ErasePolarity = 1
BlockSize     = 0x00001000
NumBlocks     = 0x380

0x00000000|0x00380000
gArmTokenSpaceGuid.PcdFvBaseAddress|gArmTokenSpaceGuid.PcdFvSize
FV = FVMAIN_COMPACT

################################################################################
#
# FV Section
#
################################################################################

#
# DXE modules (embedded compressed inside FVMAIN_COMPACT)
#
[FV.FvMain]
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE

  APRIORI DXE {
    INF MdeModulePkg/Universal/PCD/Dxe/Pcd.inf
    INF ArmPkg/Drivers/CpuDxe/CpuDxe.inf
    INF ArmPkg/Drivers/ArmGicDxe/ArmGicV3Dxe.inf
    INF ArmPkg/Drivers/TimerDxe/TimerDxe.inf
    INF MdeModulePkg/Core/RuntimeDxe/RuntimeDxe.inf
    INF MdeModulePkg/Universal/SecurityStubDxe/SecurityStubDxe.inf
    INF Platform/MikroTik/CCR2004/Drivers/PlatformGpioDxe/PlatformGpioDxe.inf
  }

  # DXE Core
  INF MdeModulePkg/Core/Dxe/DxeMain.inf

  # Architectural protocol drivers
  INF ArmPkg/Drivers/CpuDxe/CpuDxe.inf
  INF ArmPkg/Drivers/ArmGicDxe/ArmGicV3Dxe.inf
  INF ArmPkg/Drivers/TimerDxe/TimerDxe.inf
  INF MdeModulePkg/Core/RuntimeDxe/RuntimeDxe.inf
  INF MdeModulePkg/Universal/ResetSystemRuntimeDxe/ResetSystemRuntimeDxe.inf
  INF MdeModulePkg/Universal/Variable/RuntimeDxe/VariableRuntimeDxe.inf
  INF MdeModulePkg/Universal/CapsuleRuntimeDxe/CapsuleRuntimeDxe.inf
  INF MdeModulePkg/Universal/MonotonicCounterRuntimeDxe/MonotonicCounterRuntimeDxe.inf
  INF EmbeddedPkg/RealTimeClockRuntimeDxe/RealTimeClockRuntimeDxe.inf
  INF EmbeddedPkg/MetronomeDxe/MetronomeDxe.inf
  INF MdeModulePkg/Universal/WatchdogTimerDxe/WatchdogTimer.inf
  INF MdeModulePkg/Universal/SecurityStubDxe/SecurityStubDxe.inf
  INF MdeModulePkg/Universal/BdsDxe/BdsDxe.inf

  # Infrastructure
  INF MdeModulePkg/Universal/PCD/Dxe/Pcd.inf
  INF MdeModulePkg/Universal/DevicePathDxe/DevicePathDxe.inf
  INF MdeModulePkg/Universal/HiiDatabaseDxe/HiiDatabaseDxe.inf
  INF MdeModulePkg/Universal/SmbiosDxe/SmbiosDxe.inf
  INF Platform/MikroTik/CCR2004/Drivers/SmbiosPlatformDxe/SmbiosPlatformDxe.inf

  # PCI
  INF ArmPkg/Drivers/ArmPciCpuIo2Dxe/ArmPciCpuIo2Dxe.inf
  INF MdeModulePkg/Bus/Pci/PciHostBridgeDxe/PciHostBridgeDxe.inf
  INF MdeModulePkg/Bus/Pci/PciBusDxe/PciBusDxe.inf

  # Serial console
  INF MdeModulePkg/Universal/SerialDxe/SerialDxe.inf
  INF MdeModulePkg/Universal/Console/ConSplitterDxe/ConSplitterDxe.inf
  INF MdeModulePkg/Universal/Console/ConPlatformDxe/ConPlatformDxe.inf
  INF MdeModulePkg/Universal/Console/TerminalDxe/TerminalDxe.inf

  # Disk I/O, Partition (MBR/GPT), FAT filesystem
  INF MdeModulePkg/Universal/Disk/DiskIoDxe/DiskIoDxe.inf
  INF MdeModulePkg/Universal/Disk/PartitionDxe/PartitionDxe.inf
  INF FatPkg/EnhancedFatDxe/Fat.inf

  # GPIO
  INF Platform/MikroTik/CCR2004/Drivers/PlatformGpioDxe/PlatformGpioDxe.inf
  INF ArmPlatformPkg/Drivers/PL061GpioDxe/PL061GpioDxe.inf

  # I2C
  INF Platform/MikroTik/CCR2004/Drivers/DwI2cDxe/DwI2cDxe.inf
  INF Platform/MikroTik/CCR2004/Drivers/Pca954xDxe/Pca954xDxe.inf
  INF Platform/MikroTik/CCR2004/Drivers/FanDxe/FanDxe.inf
  INF MdeModulePkg/Bus/I2c/I2cDxe/I2cHostDxe.inf

  # SPI + SPI NOR Flash + NVRAM persistence
  INF Platform/MikroTik/CCR2004/Drivers/SpiNorFlashDxe/SpiNorFlashDxe.inf
  INF Platform/MikroTik/CCR2004/Drivers/BoardInfoDxe/BoardInfoDxe.inf
  INF Platform/MikroTik/CCR2004/Drivers/NvramPersistDxe/NvramPersistDxe.inf

  # NAND
  INF Platform/MikroTik/CCR2004/Drivers/AlNandDxe/AlNandDxe.inf

  # YAFFS2 filesystem
  INF Platform/MikroTik/CCR2004/Drivers/MtYaffs2Dxe/MtYaffs2Dxe.inf

  # Device Tree
  INF Platform/MikroTik/CCR2004/Drivers/DtPatchDxe/DtPatchDxe.inf
  FILE FREEFORM = 25462CDA-221F-47DF-AC1D-259CFAA4E326 {
    SECTION RAW = Platform/MikroTik/CCR2004/Resources/DeviceTree/CCR2004-1G-2XS-PCIe.dtb
  }

  # Ethernet (HAL-based)
  INF Platform/MikroTik/CCR2004/Drivers/AlEthNextDxe/AlEthNextDxe.inf

  # Security services (RNG + Hash2, required by network stack)
  INF SecurityPkg/RandomNumberGenerator/RngDxe/RngDxe.inf
  INF SecurityPkg/Hash2DxeCrypto/Hash2DxeCrypto.inf

  # RAM Disk
  INF MdeModulePkg/Universal/Disk/RamDiskDxe/RamDiskDxe.inf

  # Network Stack
!include NetworkPkg/Network.fdf.inc

  # Unicode Collation (required by Shell)
  INF MdeModulePkg/Universal/Disk/UnicodeCollation/EnglishDxe/EnglishDxe.inf

  # Form Browser (required by UiApp)
  INF MdeModulePkg/Universal/SetupBrowserDxe/SetupBrowserDxe.inf
  INF MdeModulePkg/Universal/DisplayEngineDxe/DisplayEngineDxe.inf

  # Setup UI
  INF MdeModulePkg/Application/UiApp/UiApp.inf
  INF MdeModulePkg/Application/BootManagerMenuApp/BootManagerMenuApp.inf

  # FV as filesystem
  INF MdeModulePkg/Universal/FvSimpleFileSystemDxe/FvSimpleFileSystemDxe.inf

  # Shell applications
  INF Platform/MikroTik/CCR2004/Application/BoardI2cEepromProbeApp/BoardI2cEepromProbeApp.inf
  INF Platform/MikroTik/CCR2004/Application/FormatBlockApp/FormatBlockApp.inf
  INF Platform/MikroTik/CCR2004/Application/NandProbeApp/NandProbeApp.inf
  INF Platform/MikroTik/CCR2004/Application/DumpBlockApp/DumpBlockApp.inf
  INF Platform/MikroTik/CCR2004/Application/TftpPutApp/TftpPutApp.inf

  # SPI flash update utility
  INF Platform/MikroTik/CCR2004/Application/FlashApp/FlashApp.inf

  # SRAM shared data dump
  INF Platform/MikroTik/CCR2004/Application/SramDumpApp/SramDumpApp.inf


  # RouterBoot chainloader + binary
  INF Platform/MikroTik/CCR2004/Application/RouterBootApp/RouterBootApp.inf
  FILE FREEFORM = 7D3A1B2E-C5F8-4A69-B012-4E8C6D1F3A95 {
    SECTION RAW = Platform/MikroTik/CCR2004/Resources/RouterBoot/routerboot-7.12.bin
  }

  # RouterOS Kernel Loader
  INF Platform/MikroTik/CCR2004/Application/RouterOSLoader/RouterOSLoader.inf

  # UEFI Shell + dynamic commands
  INF ShellPkg/Application/Shell/Shell.inf
  INF ShellPkg/DynamicCommand/TftpDynamicCommand/TftpDynamicCommand.inf
  INF ShellPkg/DynamicCommand/HttpDynamicCommand/HttpDynamicCommand.inf

#
# Boot FV: PeilessSec + compressed DXE FV
#
[FV.FVMAIN_COMPACT]
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE

  INF ArmPlatformPkg/PeilessSec/PeilessSec.inf

  FILE FV_IMAGE = 9E21FD93-9C72-4c15-8C4B-E77F1DB2D792 {
    SECTION COMPRESS {
      SECTION FV_IMAGE = FvMain
    }
  }

################################################################################
#
# Rules Section
#
################################################################################

[Rule.Common.SEC]
  FILE SEC = $(NAMED_GUID) RELOCS_STRIPPED FIXED {
    TE TE Align = Auto $(INF_OUTPUT)/$(MODULE_NAME).efi
  }

[Rule.Common.DXE_CORE]
  FILE DXE_CORE = $(NAMED_GUID) {
    PE32 PE32 $(INF_OUTPUT)/$(MODULE_NAME).efi
    UI STRING ="$(MODULE_NAME)" Optional
  }

[Rule.Common.DXE_DRIVER]
  FILE DRIVER = $(NAMED_GUID) {
    DXE_DEPEX DXE_DEPEX Optional $(INF_OUTPUT)/$(MODULE_NAME).depex
    PE32 PE32 $(INF_OUTPUT)/$(MODULE_NAME).efi
    UI STRING ="$(MODULE_NAME)" Optional
  }

[Rule.Common.DXE_RUNTIME_DRIVER]
  FILE DRIVER = $(NAMED_GUID) {
    DXE_DEPEX DXE_DEPEX Optional $(INF_OUTPUT)/$(MODULE_NAME).depex
    PE32 PE32 $(INF_OUTPUT)/$(MODULE_NAME).efi
    UI STRING ="$(MODULE_NAME)" Optional
  }

[Rule.Common.UEFI_DRIVER]
  FILE DRIVER = $(NAMED_GUID) {
    DXE_DEPEX DXE_DEPEX Optional $(INF_OUTPUT)/$(MODULE_NAME).depex
    PE32 PE32 $(INF_OUTPUT)/$(MODULE_NAME).efi
    UI STRING ="$(MODULE_NAME)" Optional
  }

[Rule.Common.UEFI_APPLICATION]
  FILE APPLICATION = $(NAMED_GUID) {
    PE32 PE32 $(INF_OUTPUT)/$(MODULE_NAME).efi
    UI STRING ="$(MODULE_NAME)" Optional
  }
