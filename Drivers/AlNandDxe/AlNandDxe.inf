## @file
#  Annapurna Labs NAND controller DXE driver for MikroTik CCR2004.
#
#  Drives the AL NAND controller on the Alpine V2 SoC with Toshiba BENAND
#  flash. Produces EFI_BLOCK_IO_PROTOCOL (read-only) exposing raw NAND pages.
#  Uses AL HAL with SSM RAID DMA for accelerated page reads.
#
#  Copyright (c) 2024, MikroTik. All rights reserved.
#
#  SPDX-License-Identifier: BSD-2-Clause-Patent
#
##

[Defines]
  INF_VERSION                    = 0x0001001b
  BASE_NAME                      = AlNandDxe
  FILE_GUID                      = 8b3e4d5c-f2a1-4b07-a8ea-3fbc2e5d7f94
  MODULE_TYPE                    = DXE_DRIVER
  VERSION_STRING                 = 1.0
  ENTRY_POINT                    = AlNandDxeInitialize

[Sources]
  AlNandDxe.c
  AlNandDxe.h

[Packages]
  MdePkg/MdePkg.dec
  Platform/MikroTik/CCR2004/CCR2004.dec

[LibraryClasses]
  AlpineHalLib
  BaseLib
  BaseMemoryLib
  CacheMaintenanceLib
  DebugLib
  IoLib
  MemoryAllocationLib
  TimerLib
  UefiBootServicesTableLib
  UefiDriverEntryPoint
  UefiLib

[Protocols]
  gEfiBlockIoProtocolGuid                       ## PRODUCES
  gEfiCpuArchProtocolGuid                       ## CONSUMES
  gEfiDevicePathProtocolGuid                    ## PRODUCES
  gMikroTikNandFlashProtocolGuid                ## PRODUCES

[Depex]
  gEfiCpuArchProtocolGuid

[BuildOptions]
  GCC:*_*_AARCH64_CC_FLAGS = -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/include/common -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/include/udma -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/include/iofic -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/include/io_fabric -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/include/ssm -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/include/pbs -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/drivers/ssm -I$(WORKSPACE)/edk2-platforms/Platform/MikroTik/CCR2004/Library/AlpineHalLib/drivers/pbs -include al_hal_plat_types.h -include al_hal_plat_services.h
